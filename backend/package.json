{
  "name": "budget-app-backend",
  "version": "0.1.0",
  "description": "Secure personal budgeting application API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec \"ts-node -r tsconfig-paths/register\" src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "knex migrate:latest",
    "migrate:make": "knex migrate:make",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:status": "knex migrate:status",
    "seed": "node -r ts-node/register -r tsconfig-paths/register node_modules/.bin/knex seed:run",
    "seed:dev": "node -r ts-node/register -r tsconfig-paths/register node_modules/.bin/knex seed:run",
    "seed:fresh": "node -e \"const e=process.env.NODE_ENV;if(['production','staging'].includes(e))throw new Error('[seed:fresh] Refusing to run in NODE_ENV='+e)\" && knex migrate:rollback --all && knex migrate:latest && node -r ts-node/register -r tsconfig-paths/register node_modules/.bin/knex seed:run",
    "search:backfill": "ts-node -r tsconfig-paths/register src/scripts/backfillSearchIndex.ts"
  },
  "keywords": [
    "budget",
    "finance",
    "personal-finance",
    "budgeting",
    "self-hosted"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@simplewebauthn/server": "^10.0.0",
    "argon2": "^0.40.0",
    "axios": "^1.7.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "joi": "^17.13.0",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "mysql2": "^3.11.0",
    "node-cron": "^3.0.3",
    "qrcode": "^1.5.4",
    "redis": "^4.7.0",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.5.0",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "winston": "^3.14.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ]
  }
}
